rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers de acceso ──
    function isAuth()       { return request.auth != null; }
    function isOwner(uid)   { return request.auth.uid == uid; }
    function isAdmin()      {
      return isAuth() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ═══════════════════════════════════════════════════════════
    //  users/{uid} — Documento raíz de acceso y configuración
    //  Contiene: is_pro, role, trial_ends_at, stripe_customer_id, fcm_token
    // ═══════════════════════════════════════════════════════════
    match /users/{uid} {
      // El usuario puede leer su propio doc (para checkUserAccess y notificaciones)
      allow read: if isAuth() && isOwner(uid);

      // El usuario puede crear su doc en el registro
      allow create: if isAuth() && isOwner(uid);

      // El usuario puede actualizar SOLO los campos permitidos (no puede darse Pro a sí mismo)
      allow update: if isAuth() && isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['is_pro', 'role', 'stripe_customer_id']);

      // Admins pueden leer/escribir todo
      allow read, write: if isAdmin();

      // ── users/{uid}/data/{doc} — Datos de productividad de la app ──
      match /data/{doc} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      // ── users/{uid}/connections/{connectionId} — Aliados/conexiones ──
      match /connections/{connectionId} {
        allow read, write: if isAuth() && isOwner(uid);
      }

      // ── users/{uid}/user_activity/{activityId} — Historial de actividad ──
      match /user_activity/{activityId} {
        allow read:   if isAuth() && isOwner(uid);
        allow create: if isAuth() && isOwner(uid)
          && request.resource.data.keys().hasAll(['type','xp_earned','completed_at','label'])
          && request.resource.data.type in ['task','habit','workout','finance'];
        allow update, delete: if false;
      }

      // ── users/{uid}/transactions/{txId} — Transacciones financieras (Cloud-First) ──
      // Cada transacción es un documento individual. Soft-delete vía campo 'deleted'.
      match /transactions/{txId} {
        allow read:   if isAuth() && isOwner(uid);
        allow create: if isAuth() && isOwner(uid)
          && request.resource.data.keys().hasAll(['amount','type','scope','date','deleted'])
          && request.resource.data.type in ['entrada','salida']
          && request.resource.data.amount is number
          && request.resource.data.amount > 0;
        // Solo permite actualizar campos seguros (soft-delete, edición de monto/descripción)
        allow update: if isAuth() && isOwner(uid)
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['type','scope','createdAt']);
      }

      // ── users/{uid}/entrenamientos/{entId} — Historial de sesiones de gym ──
      match /entrenamientos/{entId} {
        allow read:   if isAuth() && isOwner(uid);
        allow create: if isAuth() && isOwner(uid);
      }
    }

    // ═══════════════════════════════════════════════════════════
    //  gemelo_data/{uid} — Análisis del Gemelo Potenciado
    //  IMPORTANTE: Los clientes NUNCA pueden leer este documento directamente.
    //  La lectura solo ocurre a través de la Cloud Function getGemelo,
    //  que valida el acceso antes de exponer analysis_text.
    //  (Cloud Functions usan Admin SDK que bypasea estas reglas)
    // ═══════════════════════════════════════════════════════════
    match /gemelo_data/{uid} {
      // El cliente puede ESCRIBIR su propio doc (el análisis se genera localmente)
      allow write: if isAuth() && isOwner(uid);
      // LECTURA BLOQUEADA desde el cliente — solo se permite via Cloud Function (Admin SDK)
      allow read: if false;
    }

    // ═══════════════════════════════════════════════════════════
    //  noticias/{docId} — Contenido educativo de la sección Aprende
    //  Solo lectura pública para usuarios autenticados
    // ═══════════════════════════════════════════════════════════
    match /noticias/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    //  leaderboard/{uid} — Ranking público semanal
    //  Cualquier usuario autenticado puede leer el ranking completo.
    //  Cada usuario solo puede escribir su propio documento.
    //  Ni admins ni terceros pueden modificar el doc de otro usuario.
    // ═══════════════════════════════════════════════════════════
    match /leaderboard/{uid} {
      allow read:  if isAuth();
      allow write: if isAuth() && isOwner(uid);
    }

    // ═══════════════════════════════════════════════════════════
    //  userDirectory/{uid} — Perfil público para búsqueda de aliados
    //  Cualquier usuario autenticado puede buscar/leer perfiles.
    //  Cada usuario solo escribe/actualiza su propio perfil.
    // ═══════════════════════════════════════════════════════════
    match /userDirectory/{uid} {
      allow read:   if isAuth();
      allow create: if isAuth() && isOwner(uid);
      allow update: if isAuth() && isOwner(uid);
    }

    // ═══════════════════════════════════════════════════════════
    //  friendRequests/{reqId} — Solicitudes de amistad (Fix 4.1)
    //  Formato de reqId: "{fromUid}_{toUid}"
    //  - El remitente puede crear y cancelar su propia solicitud.
    //  - El destinatario puede leer y actualizar el estado (aceptar/rechazar).
    //  - Nadie más puede acceder.
    // ═══════════════════════════════════════════════════════════
    match /friendRequests/{reqId} {
      // Leer: el remitente o el destinatario
      allow read: if isAuth()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid  == request.auth.uid);

      // Crear: solo el remitente puede crear, y solo para sí mismo
      allow create: if isAuth()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.status  == 'pending'
        && request.resource.data.keys().hasAll(['fromUid','toUid','fromNombre','status','sentAt']);

      // Actualizar: solo el destinatario puede cambiar el status
      allow update: if isAuth()
        && resource.data.toUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['accepted','rejected'];

      // Eliminar: el remitente puede cancelar su solicitud
      allow delete: if isAuth() && resource.data.fromUid == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════
    //  analytics/{uid}/eventos — Telemetría silenciosa
    //  El cliente SOLO puede crear eventos propios (no leer, no editar, no borrar).
    //  Lectura reservada al Admin SDK (Cloud Functions / consola de admin).
    //  Estos datos alimentan el Gemelo Potenciado vía generateGemeloAnalysis.
    // ═══════════════════════════════════════════════════════════
    match /analytics/{uid}/eventos/{eventId} {
      // Crear: solo el propio usuario puede escribir sus eventos
      allow create: if isAuth() && isOwner(uid)
        && request.resource.data.keys().hasAll(['tipo', 'timestamp', 'uid'])
        && request.resource.data.uid == request.auth.uid;
      // Lectura y escritura admin → solo vía Admin SDK (bypasea estas reglas)
      allow read, update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════
    //  Bloquear todo lo no definido explícitamente
    // ═══════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
