rules_version = '2';
// ⚠️ STAGING ONLY — reglas permisivas para pruebas automatizadas de OpenClaw
// NUNCA desplegar este archivo en producción
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
